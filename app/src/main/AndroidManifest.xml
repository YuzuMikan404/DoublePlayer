<?xml version="1.0" encoding="utf-8"?>
<!--
    AndroidManifest.xml - DoublePlayer
    仕様書セクション11「必要なAndroidパーミッション」に基づいて記述する
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ========== パーミッション宣言 ========== -->

    <!-- Bluetooth接続状態の確認（Android 12以上） -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />

    <!-- 外部ストレージの音声ファイル読み込み（Android 13以上） -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- 外部ストレージ読み込み（Android 12以下） -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- フォアグラウンドサービス（バックグラウンド再生） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- 通知表示（Android 13以上） -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 端末起動時にアプリを自動起動（将来の拡張用） -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- インターネット接続（祝日API用） -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- ========== アプリケーション定義 ========== -->

    <application
        android:name=".DoublePlayerApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DoublePlayer">

        <!-- ========== MainActivity ========== -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <!-- ランチャーから起動できるようにする -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ========== PlayerService ========== -->
        <!--
            ForegroundServiceとして動作するメディア再生サービス
            type="mediaPlayback"でメディア再生用フォアグラウンドサービスとして宣言する
        -->
        <service
            android:name=".player.PlayerService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- ========== BluetoothReceiver ========== -->
        <!--
            Bluetooth接続・切断イベントとMacroDroid連携Broadcastを受け取るReceiver
            仕様書セクション3「BluetoothReceiver.kt」セクション7「MacroDroid連携」に対応
            android:exported="true" が必要（システム・外部アプリからのBroadcastを受け取るため）
        -->
        <receiver
            android:name=".bluetooth.BluetoothReceiver"
            android:exported="true">
            <!-- Bluetooth接続状態変化のシステムBroadcast -->
            <intent-filter>
                <action android:name="android.bluetooth.device.action.ACL_CONNECTED" />
                <action android:name="android.bluetooth.device.action.ACL_DISCONNECTED" />
                <action android:name="android.bluetooth.a2dp.profile.action.CONNECTION_STATE_CHANGED" />
            </intent-filter>
            <!-- MacroDroid（外部アプリ）からの操作Broadcast -->
            <intent-filter>
                <action android:name="com.doubleplayer.ACTION_PLAY" />
                <action android:name="com.doubleplayer.ACTION_PAUSE" />
                <action android:name="com.doubleplayer.ACTION_STOP" />
                <action android:name="com.doubleplayer.ACTION_NEXT" />
                <action android:name="com.doubleplayer.ACTION_PREV" />
                <action android:name="com.doubleplayer.ACTION_TOGGLE" />
            </intent-filter>
        </receiver>

        <!-- ========== ホーム画面ウィジェット ========== -->
        <!--
            PlayerWidgetReceiver - GlanceAppWidgetReceiverを継承したウィジェットReceiver
        -->
        <receiver
            android:name=".widget.PlayerWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <!-- ウィジェットのメタデータ -->
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/player_widget_info" />
        </receiver>

        <!-- ========== FileProvider（設定エクスポート用） ========== -->
        <!--
            BackupManagerがキャッシュフォルダに書き出したJSONファイルを
            他のアプリと共有するためのFileProvider
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="@string/file_provider_authority"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_provider_paths" />
        </provider>

    </application>

</manifest>
